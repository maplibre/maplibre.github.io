---
import Layout from "../../layouts/Layout.astro";
---

<style lang="css">
  .section-odd {
    background: #111725;
  }

  .benefit-badge {
    background: rgba(255, 255, 255, 0.1);
  }

  .stat-card {
    background: #285daa;
  }

  .ecosystem-border {
    border-left: 3px solid #285daa;
  }

  .demo-card {
    transition: transform 0.2s ease;
  }

  .demo-card:hover {
    transform: translateY(-4px);
  }
</style>

<Layout title="MapLibre GL JS">
  <section class="py-5 px-4 text-center text-white section-odd">
    <div class="container">
      <h1 class="display-4 mb-3">MapLibre GL JS</h1>
      <p class="lead mb-4 opacity-75">
        The open-source TypeScript library for publishing interactive,
        GPU-accelerated maps on the web.
      </p>

      <div class="d-flex flex-wrap justify-content-center gap-3 mt-5">
        <div class="benefit-badge rounded px-3 py-2 fs-6">🤝 Open Source</div>
        <div class="benefit-badge rounded px-3 py-2 fs-6">
          👥 Community Governed
        </div>
        <div class="benefit-badge rounded px-3 py-2 fs-6">
          🚀 GPU-Accelerated
        </div>
        <div class="benefit-badge rounded px-3 py-2 fs-6">🌐 Web-Native</div>
        <div class="benefit-badge rounded px-3 py-2 fs-6">🔌 Extensible</div>
        <div class="benefit-badge rounded px-3 py-2 fs-6">🌍 Globe Support</div>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center bg-light text-dark">
    <div class="container">
      <h2 class="h1 mb-3">Built for the Web Platform</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        MapLibre GL JS is a TypeScript library that renders interactive maps
        from vector tiles and MapLibre Style Specification directly in the
        browser, using WebGL and WebGPU for exceptional performance.
      </p>

      <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
              <div class="fs-1 mb-2">⚡</div>
              <h3 class="card-title h5 text-primary">High Performance</h3>
              <p class="card-text text-dark small">
                GPU-accelerated rendering with WebGL and WebGPU for silky-smooth
                60fps maps
              </p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
              <div class="fs-1 mb-2">🌐</div>
              <h3 class="card-title h5 text-primary">Globe &amp; 3D</h3>
              <p class="card-text text-dark small">
                Render a full globe, 3D terrain, building extrusions, and custom
                3D layers with ease
              </p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
              <div class="fs-1 mb-2">🎨</div>
              <h3 class="card-title h5 text-primary">Rich Styling</h3>
              <p class="card-text text-dark small">
                Powerful MapLibre Style Specification with data-driven
                expressions for dynamic, beautiful maps
              </p>
            </div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div class="card h-100 shadow-sm">
            <div class="card-body text-center">
              <div class="fs-1 mb-2">🔌</div>
              <h3 class="card-title h5 text-primary">Extensible</h3>
              <p class="card-text text-dark small">
                Plugin-friendly architecture with support for custom sources,
                layers, and controls
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center text-white section-odd">
    <div class="container">
      <h2 class="h1 mb-3">Modern Rendering Technologies</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        MapLibre GL JS supports both WebGL and the next-generation WebGPU API,
        ensuring the best visual quality and performance in modern browsers.
      </p>

      <div
        class="row g-4 justify-content-center"
        style="max-width: 600px; margin: 0 auto;"
      >
        <div class="col-md-6 col-12">
          <div class="card h-100 shadow-sm">
            <div
              class="card-body d-flex flex-column align-items-center text-center"
            >
              <div class="fs-1 mb-3">🖥️</div>
              <h3 class="card-title h5 text-primary">WebGL</h3>
              <p class="card-text text-dark small">
                Battle-tested GPU rendering available in every modern browser
              </p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-12">
          <div class="card h-100 shadow-sm">
            <div
              class="card-body d-flex flex-column align-items-center text-center"
            >
              <div class="fs-1 mb-3">🚀</div>
              <h3 class="card-title h5 text-primary">WebGPU</h3>
              <p class="card-text text-dark small">
                Next-generation graphics API for even greater performance and
                visual fidelity
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center bg-light text-dark">
    <div class="container">
      <h2 class="h1 mb-3">What You Can Build</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        From interactive data visualizations to immersive 3D experiences,
        MapLibre GL JS gives you the tools to build any mapping application.
      </p>

      <div class="row g-4">
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/3d-terrain/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🏔️</div>
              <h4 class="card-title h6 text-primary mb-2">3D Terrain</h4>
              <p class="card-text text-dark small mb-0">
                Drape raster tiles over elevation data for stunning 3D landscape
                visualizations
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/globe-atmosphere/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🌍</div>
              <h4 class="card-title h6 text-primary mb-2">Globe View</h4>
              <p class="card-text text-dark small mb-0">
                Display a full 3D globe with atmospheric effects and vector map
                overlays
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/buildings-3d/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🏙️</div>
              <h4 class="card-title h6 text-primary mb-2">3D Buildings</h4>
              <p class="card-text text-dark small mb-0">
                Extrude polygons to create realistic 3D building and indoor
                mapping experiences
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/heatmap-layer/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🔥</div>
              <h4 class="card-title h6 text-primary mb-2">Heatmaps</h4>
              <p class="card-text text-dark small mb-0">
                Visualize point density with beautiful, customizable heatmap
                layers
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/animate-point-along-route/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">✈️</div>
              <h4 class="card-title h6 text-primary mb-2">Animations</h4>
              <p class="card-text text-dark small mb-0">
                Animate points along routes, live data streams, camera
                fly-throughs, and more
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/add-3d-model/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🤖</div>
              <h4 class="card-title h6 text-primary mb-2">Custom 3D Models</h4>
              <p class="card-text text-dark small mb-0">
                Embed three.js and Babylon.js 3D models directly into your map
                scenes
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/cluster/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">📍</div>
              <h4 class="card-title h6 text-primary mb-2">Clustering</h4>
              <p class="card-text text-dark small mb-0">
                Automatically cluster large point datasets with customizable
                styles and popups
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/population-density/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">📊</div>
              <h4 class="card-title h6 text-primary mb-2">
                Data Visualization
              </h4>
              <p class="card-text text-dark small mb-0">
                Visualize population density and other datasets with data-driven
                styling
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none demo-card ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/examples/satellite-map/"
          >
            <div class="card-body text-start">
              <div class="fs-2 mb-2">🛰️</div>
              <h4 class="card-title h6 text-primary mb-2">
                Satellite &amp; Raster
              </h4>
              <p class="card-text text-dark small mb-0">
                Display satellite imagery, raster tiles, COG sources, and WMS
                layers
              </p>
            </div>
          </a>
        </div>
      </div>

      <div class="mt-4">
        <a
          href="https://maplibre.org/maplibre-gl-js/docs/examples/"
          class="btn btn-primary btn-lg"
        >
          Browse All Examples
        </a>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center text-white section-odd">
    <div class="container">
      <h2 class="h1 mb-3">Works With Your Favorite Frameworks</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        MapLibre GL JS integrates seamlessly with popular JavaScript frameworks
        and visualization libraries through community-maintained wrappers and
        plugins.
      </p>

      <div class="row g-4">
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">React</h4>
              <p class="card-text text-dark small mb-0">
                React MapLibre — idiomatic React bindings for MapLibre GL JS
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">Angular</h4>
              <p class="card-text text-dark small mb-0">
                ngx-maplibre-gl — Angular components for embedding MapLibre maps
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">Vue</h4>
              <p class="card-text text-dark small mb-0">
                vue-maplibre-gl — MapLibre GL JS integration for Vue 3
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">deck.gl</h4>
              <p class="card-text text-dark small mb-0">
                Create large-scale WebGL-powered data visualizations on top of
                MapLibre maps
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">three.js</h4>
              <p class="card-text text-dark small mb-0">
                Embed full 3D three.js scenes as custom map layers with terrain
                support
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">Babylon.js</h4>
              <p class="card-text text-dark small mb-0">
                Integrate Babylon.js 3D models and scenes into your map
                application
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">terra-draw</h4>
              <p class="card-text text-dark small mb-0">
                Draw and edit geometries directly on your MapLibre map with
                terra-draw
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">PMTiles</h4>
              <p class="card-text text-dark small mb-0">
                Serve single-file tile archives directly from cloud storage with
                no tile server required
              </p>
            </div>
          </a>
        </div>
        <div class="col-lg-4 col-md-6 col-12">
          <a
            class="card h-100 shadow-sm text-decoration-none ecosystem-border"
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
          >
            <div class="card-body text-start">
              <h4 class="card-title h6 text-primary mb-2">Mapbox GL Draw</h4>
              <p class="card-text text-dark small mb-0">
                Add draw and edit tools for GeoJSON polygons and shapes to your
                map
              </p>
            </div>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center bg-light text-dark">
    <div class="container">
      <h2 class="h1 mb-3">Supported by Leading Companies</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        Major companies rely on MapLibre GL JS for their mapping needs,
        contributing time and money to its development and ensuring
        enterprise-grade quality.
      </p>

      <div class="d-flex flex-wrap justify-content-center gap-3">
        <a href="https://madewithmaplibre.com/" class="btn btn-primary btn-lg">
          Who is using us
        </a>
        <a href="/sponsors" class="btn btn-primary btn-lg"> Our sponsors </a>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center text-white section-odd">
    <div class="container">
      <h2 class="h1 mb-3">Vibrant Open Source Community</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        Join thousands of developers contributing to the future of open mapping
        technology on the web.
      </p>

      <div class="row g-4 justify-content-center">
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div
            class="stat-card rounded p-4 text-white text-center h-100 d-flex flex-column justify-content-center"
          >
            <div class="display-4 fw-bold mb-2">7K+</div>
            <div class="fs-5 opacity-75">GitHub Stars</div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div
            class="stat-card rounded p-4 text-white text-center h-100 d-flex flex-column justify-content-center"
          >
            <div class="display-4 fw-bold mb-2">300+</div>
            <div class="fs-5 opacity-75">Contributors</div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div
            class="stat-card rounded p-4 text-white text-center h-100 d-flex flex-column justify-content-center"
          >
            <div class="display-4 fw-bold mb-2">1,000+</div>
            <div class="fs-5 opacity-75">Community Members</div>
          </div>
        </div>
        <div class="col-lg-3 col-md-6 col-sm-6">
          <div
            class="stat-card rounded p-4 text-white text-center h-100 d-flex flex-column justify-content-center"
          >
            <div class="display-4 fw-bold mb-2">100%</div>
            <div class="fs-5 opacity-75">Open Source</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-5 px-4 text-center bg-light text-dark">
    <div class="container">
      <h2 class="h1 mb-3">Learn More</h2>
      <p class="lead mb-5 mx-auto" style="max-width: 600px;">
        Explore documentation, examples, and resources to get started with
        MapLibre GL JS.
      </p>

      <div class="d-flex flex-wrap justify-content-center gap-2">
        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://github.com/maplibre/maplibre-gl-js"
            class="text-decoration-none text-white"
          >
            <svg
              role="img"
              class="me-1"
              style="width: 16px; height: 16px; fill: currentColor;"
              viewBox="0 0 24 24"
              xmlns="http://www.w3.org/2000/svg"
            >
              <title>GitHub</title>
              <path
                d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
              ></path>
            </svg>
            GitHub
          </a>
        </span>

        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://maplibre.org/maplibre-gl-js/docs/"
            class="text-decoration-none text-white"
          >
            API Documentation
          </a>
        </span>

        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://maplibre.org/maplibre-gl-js/docs/examples/"
            class="text-decoration-none text-white"
          >
            Examples
          </a>
        </span>

        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://maplibre.org/maplibre-gl-js/docs/plugins/"
            class="text-decoration-none text-white"
          >
            Plugins
          </a>
        </span>

        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://maplibre.org/maplibre-style-spec"
            class="text-decoration-none text-white"
          >
            Style Spec
          </a>
        </span>

        <span class="badge bg-primary fs-6 p-2">
          <a
            href="https://github.com/maplibre/maplibre-gl-js/releases"
            class="text-decoration-none text-white"
          >
            Releases
          </a>
        </span>
      </div>
    </div>
  </section>
</Layout>
