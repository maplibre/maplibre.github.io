---
import "../styles/bootstrap.scss";
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../constants";
const { title, description, ogType = "website", ogImage } = Astro.props;
import { ClientRouter, fade } from "astro:transitions";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const defaultOgImage = new URL("/img/share-image.png", Astro.site).href;
const socialImage = ogImage || defaultOgImage;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="author" content="MapLibre" />
    <meta name="description" content={description || SITE_DESCRIPTION} />
    <link rel="canonical" href={canonicalUrl} />
    <ClientRouter />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="512" />
    <meta property="og:image:alt" content="MapLibre" />
    <meta property="og:title" content={title || SITE_TITLE} />
    <meta property="og:description" content={description || SITE_DESCRIPTION} />
    <meta property="og:url" content={canonicalUrl.href} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@maplibre" />
    <meta name="twitter:creator" content="@maplibre" />
    <meta name="twitter:title" content={title || SITE_TITLE} />
    <meta
      name="twitter:description"
      content={description || SITE_DESCRIPTION}
    />
    <meta name="twitter:image:src" content={socialImage} />
    <meta name="twitter:image:alt" content="MapLibre" />

    <link rel="manifest" href="/site.webmanifest" />

    <link rel="me" href="https://mastodon.social/@maplibre" />

    <link
      rel="preload"
      href="/files/alata-latin-400-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <link
      rel="prefetch"
      href="https://demotiles.maplibre.org/style.json"
      as="fetch"
      crossorigin
    />
    <link
      rel="prefetch"
      href="https://demotiles.maplibre.org/tiles/tiles.json"
      as="fetch"
      crossorigin
    />

    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_TITLE}
      href={new URL("news/index.xml", Astro.site)}
    />

    <slot name="head" />

    <title>
      {title ? `${title} | ${SITE_TITLE}` : SITE_TITLE}
    </title>
  </head>
  <body transition:animate={fade({ duration: "0.2s" })}>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
      crossorigin="anonymous"></script>
    <Nav />

    <slot />

    <Footer />
  </body>
</html>

<style>
  html {
    height: 100%;
  }

  body {
    margin: 0;
    width: 100%;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }
</style>
