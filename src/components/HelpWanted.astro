---
interface Props {
  developer?: string;
  funding?: string;
}

const { developer, funding } = Astro.props;
---

<div class="mt-4">
  <h5>Get Involved</h5>
  <div class="d-flex gap-3 flex-wrap mt-2">
    {
      developer && (
        <a href={developer} class="btn btn-outline-light">
          Technical Discussion
        </a>
      )
    }
    {
      funding && (
        <a href={funding} class="btn btn-primary">
          Funding
        </a>
      )
    }
  </div>
</div>
