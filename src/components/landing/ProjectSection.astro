---
import { Icon } from "astro-icon/components";

interface Props {
  title: string;
  visualStyle?: string;
  visualFlex?: boolean;
  href?: string;
}

const { title, visualStyle = "", visualFlex = true, href } = Astro.props;

const visualBaseStyle = visualFlex
  ? "display: flex; justify-content: center; align-items: center;"
  : "";
const fullVisualStyle = [visualBaseStyle, visualStyle]
  .filter(Boolean)
  .join(" ");

const titleText = title.replace(/<[^>]+>/g, "");
---

<hr />
<div
  class:list={[
    "container",
    { "project-link": !!href, "position-relative": !!href, rounded: !!href },
  ]}
>
  {
    href && (
      <a
        href={href}
        class="stretched-link"
        aria-label={`Read more about ${titleText}`}
      />
    )
  }
  <div class="row">
    <div
      class="col-md-12 col-lg-6"
      style="display: flex; flex-direction: column; justify-content: center;"
    >
      <div>
        <h1 style="color: white;" set:html={title} />

        <slot name="description" />
        <br /><br />

        <div
          class:list={[
            { "position-relative z-2 gap": !!href },
            "badges-container",
          ]}
        >
          <slot name="badges" />
        </div>
        {
          href && (
            <div class="position-relative z-2 pt-4 pb-3 explore-btn-wrapper">
              <a href={href} class="explore-btn">
                Explore {titleText}
                <Icon
                  name="chevron-right"
                  aria-hidden="true"
                  height={14}
                  width={14}
                />
              </a>
            </div>
          )
        }
        <br />
      </div>
    </div>
    <div class="col-md-12 col-lg-6" style={fullVisualStyle || undefined}>
      <slot name="visual" />
    </div>
  </div>
</div>

<style lang="scss">
  .project-link {
    transition: background-color 0.3s ease;

    &:hover {
      background-color: #111422;
    }
  }

  .badges-container {
    display: grid;
    grid-template-columns: repeat(3, max-content);
    gap: 0.8rem 3rem;
    align-items: center;

    @media (max-width: 575.98px) {
      grid-template-columns: repeat(2, max-content);
      justify-content: center;
      justify-items: center;
      text-align: center;
    }

    @media (max-width: 399.98px) {
      grid-template-columns: repeat(1, max-content);
    }
  }

  .explore-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #fff;
    background-color: #285daa;
    border-radius: 4px;
    padding: 0.375rem 0.875rem;
    text-decoration: none;
    font-size: 0.9rem;

    &:hover {
      background-color: #3470c4;
    }
  }

  .explore-btn-wrapper {
    @media (max-width: 399.98px) {
      text-align: center;
    }
  }
</style>
