---
interface Props {
  title: string;
  visualStyle?: string;
  visualFlex?: boolean;
  href?: string;
}

const { title, visualStyle = "", visualFlex = true, href } = Astro.props;

const visualBaseStyle = visualFlex
  ? "display: flex; justify-content: center; align-items: center;"
  : "";
const fullVisualStyle = [visualBaseStyle, visualStyle]
  .filter(Boolean)
  .join(" ");

const titleText = title.replace(/<[^>]+>/g, "");
---

<hr />
<div
  class:list={[
    "container",
    { "project-link": !!href, "position-relative": !!href, rounded: !!href },
  ]}
>
  {
    href && (
      <a
        href={href}
        class="stretched-link"
        aria-label={`Learn more about ${titleText}`}
      />
    )
  }
  <div class="row">
    <div
      class="col-md-12 col-lg-6"
      style="display: flex; flex-direction: column; justify-content: center;"
    >
      <div>
        <h1 style="color: white;" set:html={title} />

        <slot name="description" />
        <br /><br />

        <div class:list={[{ "position-relative z-2": !!href }]}>
          <slot name="badges" />
        </div>
        {
          href && (
            <div class="position-relative z-2 mt-3 pb-3">
              <a href={href} class="explore-btn">
                Learn more about {titleText}
              </a>
            </div>
          )
        }
        <br />
      </div>
    </div>
    <div class="col-md-12 col-lg-6" style={fullVisualStyle || undefined}>
      <slot name="visual" />
    </div>
  </div>
</div>

<style lang="scss">
  .project-link {
    transition: background-color 0.3s ease;

    &:hover {
      background-color: #111422;
    }
  }

  .explore-btn {
    display: inline-block;
    color: #000;
    background-color: #95befa;
    border-radius: 4px;
    padding: 0.375rem 0.875rem;
    text-decoration: none;
    font-size: 0.9rem;

    &:hover {
      background-color: #aecdfb;
    }
  }
</style>
