---
interface Props {
  href: string;
  src: string;
  alt: string;
  large?: boolean;
  small?: boolean;
}

const { href, src, alt, large = false, small = false } = Astro.props;
const containerHeight = large ? "120px" : small ? "40px" : "70px";
const logoModifier = large ? " logo-large" : small ? " logo-small" : "";
---

<style>
  /* Bootstrap has no filter/transition utilities — kept as custom CSS */
  .logo {
    height: 48px;
    max-width: 144px;
    filter: grayscale(100%) opacity(0.7);
    transition: filter 0.2s ease;
  }

  .logo.logo-large {
    height: 96px;
    max-width: 240px;
  }

  .logo.logo-small {
    height: 24px;
    max-width: 72px;
  }

  .logo:hover {
    filter: grayscale(0%) opacity(1);
  }
</style>

<a
  href={href}
  title={alt}
  class="d-flex align-items-center justify-content-center text-decoration-none"
  style={`height: ${containerHeight};`}
>
  <img
    src={src}
    alt={alt}
    class={`w-auto object-fit-contain logo${logoModifier}`}
  />
</a>
