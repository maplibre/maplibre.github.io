---
// src/components/Announcement.astro
---

<div class="announcement-callout">
  <div class="announcement-content">
    <slot />
  </div>
</div>

<style>
  .announcement-callout {
    background-color: rgba(66, 153, 225, 0.1);
    border-left: 4px solid #4299e1;
    padding: 20px;
    margin: 24px 0;
    border-radius: 4px;
    display: flex;
    align-items: flex-start; /* Aligns icon with the top of the text */
    gap: 16px;
  }

  .announcement-content {
    color: #e2e8f0;
    font-size: 1rem;
    line-height: 1.6;
  }

  /* Ensures any links inside are still readable but not buttons */
  .announcement-content :global(a) {
    color: #63b3ed;
    text-decoration: underline;
    font-weight: 600;
  }

  .announcement-content :global(a:hover) {
    color: #90cdf4;
  }

  /* Removes margin from the last paragraph inside the slot */
  .announcement-content :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
